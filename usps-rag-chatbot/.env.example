# USPS RAG Chatbot — environment variables
# Copy to .env and fill in your keys.

# LLM provider: "anthropic" | "openai" | "echo" (echo = stub for offline testing)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embeddings: "sentence-transformers" | "echo"
EMBEDDINGS_PROVIDER=sentence-transformers
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector store: "faiss" (only FAISS implemented; easy to swap via interface)
VECTOR_STORE=faiss
INDEX_PATH=./backend/rag/_index

# RAG tuning
TOP_K=5
MIN_SCORE=0.25
MAX_CONTEXT_CHARS=8000

# API
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000,http://127.0.0.1:5500
LOG_LEVEL=INFO
