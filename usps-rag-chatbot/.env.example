# USPS RAG Chatbot — environment variables
# Copy to .env and fill in your keys.

# LLM provider: "ollama" | "anthropic" | "openai" | "echo"
#   ollama = local open-source models (default; free, no API key needed)
#   anthropic / openai = hosted API (requires key + credits)
#   echo = stub for offline testing (no generation, just retrieval)
LLM_PROVIDER=ollama

# Ollama — install from https://ollama.com/download then `ollama pull llama3.1:8b`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embeddings: "sentence-transformers" | "echo"
EMBEDDINGS_PROVIDER=sentence-transformers
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector store: "faiss" (only FAISS implemented; easy to swap via interface)
VECTOR_STORE=faiss
INDEX_PATH=./backend/rag/_index

# RAG tuning
TOP_K=5
MIN_SCORE=0.25
MAX_CONTEXT_CHARS=8000

# API
# Bind to loopback by default; set to 0.0.0.0 to expose externally.
HOST=127.0.0.1
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000,http://127.0.0.1:5500
LOG_LEVEL=INFO
